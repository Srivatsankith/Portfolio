# MongoDB Atlas / MongoDB connection string
MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/portfolio?retryWrites=true&w=majority

# SMTP settings for sending contact form messages
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Portfolio Contact" <your-smtp-user@example.com>
CONTACT_TO_EMAIL=srivatsankith.toopurani@gmail.com

# Optional admin credentials
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-secure-admin-password
JWT_SECRET=replace-with-a-long-random-secret
